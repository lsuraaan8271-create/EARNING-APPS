<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Celebrity Gallery</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
}

body{
background:#0d1117;
color:#fff;
}

header{
background:linear-gradient(90deg,#6a11cb,#2575fc);
padding:25px;
text-align:center;
font-size:32px;
font-weight:bold;
box-shadow:0 5px 20px rgba(0,0,0,.4);
}

.search{
display:flex;
justify-content:center;
padding:20px;
}

.search input{
width:90%;
max-width:500px;
padding:15px;
border:none;
border-radius:30px;
font-size:18px;
outline:none;
}

.gallery{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
padding:30px;
}

.card{
background:#161b22;
border-radius:20px;
overflow:hidden;
transition:.3s;
box-shadow:0 10px 25px rgba(0,0,0,.4);
}

.card:hover{
transform:translateY(-10px);
}

.card img{
width:100%;
height:300px;
object-fit:cover;
}

.info{
padding:15px;
text-align:center;
}

.info h2{
font-size:20px;
margin-bottom:5px;
}

.info p{
color:#aaa;
}

footer{
padding:20px;
text-align:center;
color:#aaa;
}
</style>

</head>
<body>

<header>
🌟 Indian & Hollywood Celebrity Gallery
</header>

<div class="search">
<input type="text" id="search" placeholder="Search celebrity...">
</div>

<div class="gallery" id="gallery">

<div class="card">
<img src="images/shahrukh.jpg">
<div class="info">
<h2>Shah Rukh Khan</h2>
<p>Bollywood Actor</p>
</div>
</div>

<div class="card">
<img src="images/deepika.jpg">
<div class="info">
<h2>Deepika Padukone</h2>
<p>Bollywood Actress</p>
</div>
</div>

<div class="card">
<img src="images/salman.jpg">
<div class="info">
<h2>Salman Khan</h2>
<p>Bollywood Actor</p>
</div>
</div>

<div class="card">
<img src="images/alia.jpg">
<div class="info">
<h2>Alia Bhatt</h2>
<p>Bollywood Actress</p>
</div>
</div>

<div class="card">
<img src="images/tomholland.jpg">
<div class="info">
<h2>Tom Holland</h2>
<p>Hollywood Actor</p>
</div>
</div>

<div class="card">
<img src="images/scarlett.jpg">
<div class="info">
<h2>Scarlett Johansson</h2>
<p>Hollywood Actress</p>
</div>
</div>

<div class="card">
<img src="images/leonardo.jpg">
<div class="info">
<h2>Leonardo DiCaprio</h2>
<p>Hollywood Actor</p>
</div>
</div>

<div class="card">
<img src="images/emma.jpg">
<div class="info">
<h2>Emma Watson</h2>
<p>Hollywood Actress</p>
</div>
</div>

</div>

<footer>
© 2026 Celebrity Gallery
</footer>

<script>
const search=document.getElementById("search");
search.addEventListener("keyup",function(){
let filter=this.value.toLowerCase();
let cards=document.querySelectorAll(".card");

cards.forEach(card=>{
let text=card.innerText.toLowerCase();
card.style.display=text.includes(filter)?"block":"none";
});
});
</script>

</body>
</html>