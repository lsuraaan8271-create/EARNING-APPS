<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:#080b17;
background-image:
radial-gradient(circle at top left,#1e40af,transparent 35%),
radial-gradient(circle at bottom right,#9333ea,transparent 35%);
color:white;
padding:20px;
}

.container{
max-width:1100px;
margin:auto;
}

.header{
background:rgba(255,255,255,.08);
backdrop-filter:blur(18px);
border:1px solid rgba(255,255,255,.15);
border-radius:25px;
padding:40px;
text-align:center;
margin-bottom:30px;
box-shadow:0 20px 50px rgba(0,0,0,.4);
}

.header h1{
font-size:42px;
margin-bottom:10px;
}

.header p{
font-size:18px;
opacity:.8;
}

.social{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
margin-bottom:35px;
}

.social a{
text-decoration:none;
background:rgba(255,255,255,.08);
border:1px solid rgba(255,255,255,.1);
color:white;
padding:18px;
border-radius:18px;
display:flex;
justify-content:center;
align-items:center;
gap:12px;
font-size:18px;
transition:.3s;
}

.social a:hover{
transform:translateY(-6px);
background:linear-gradient(135deg,#00c6ff,#7b2ff7);
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
gap:25px;
}

.card{
background:rgba(255,255,255,.08);
backdrop-filter:blur(18px);
border-radius:22px;
padding:25px;
border:1px solid rgba(255,255,255,.12);
transition:.3s;
box-shadow:0 10px 30px rgba(0,0,0,.35);
}

.card:hover{
transform:translateY(-8px);
}

.card h2{
margin-bottom:18px;
font-size:28px;
}

.card p{
margin:10px 0;
font-size:18px;
opacity:.9;
}

.btn{
display:inline-block;
margin-top:18px;
padding:14px 30px;
border-radius:50px;
text-decoration:none;
font-weight:bold;
background:linear-gradient(135deg,#00e676,#00bcd4);
color:white;
transition:.3s;
}

.btn:hover{
transform:scale(1.05);
}

footer{
text-align:center;
padding:30px;
opacity:.7;
font-size:16px;
}

</style>

</head>
